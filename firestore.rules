rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Blogs: Publicly readable
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if false; 
    }

    // Config: Publicly readable
    match /config/{docId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
